    label: 'Côté locataire',
    tagline: 'Louer le matériel de votre événement',
    color: 'primary',
    phases: [
      {
        icon: 'user',
        title: 'Créer son compte',
        steps: [
          { name: 'Inscription', desc: 'E-mail, téléphone, mot de passe (réservé aux 18 ans et +).' },
          { name: 'Vérification e-mail', desc: 'Code à 4 chiffres pour valider l’adresse.' },
          { name: 'Compléter le profil', desc: 'Nom public, photo, et vérification d’identité (KYC).' },
        ],
      },
      {
        icon: 'search',
        title: 'Trouver le matériel',
        steps: [
          { name: 'Explorer', desc: 'Par catégorie : son, lumières, structures, réception, transport…' },
          { name: 'Rechercher & filtrer', desc: 'Par lieu, dates et fourchette de prix.' },
          { name: 'Favoris', desc: 'Mettez de côté les annonces qui vous intéressent.' },
          { name: 'Fiche produit', desc: 'Photos, prix/jour, caution, avis et profil du loueur.' },
        ],
      },
      {
        icon: 'calendar',
        title: 'Réserver & payer',
        steps: [
          { name: 'Sélectionner la période', desc: 'Choisissez vos dates au calendrier de disponibilité.' },
          { name: 'Confirmer la réservation', desc: 'Récap : durée, total, frais de service, dépôt de garantie.' },
          { name: 'Paiement sécurisé', desc: 'Carte via Stripe + empreinte de caution (non débitée).' },
          { name: 'Paiement réussi', desc: 'Numéro de transaction et prochaines étapes par e-mail.' },
        ],
      },
      {
        icon: 'box',
        title: 'Réception',
        steps: [
          { name: 'Code de réception', desc: 'Saisissez le code à 4 chiffres à la remise du matériel.' },
          { name: 'État des lieux d’entrée', desc: 'Photos + état (neuf → endommagé) au moment de la prise.' },
        ],
      },
      {
        icon: 'chat',
        title: 'Pendant la location',
        steps: [
          { name: 'Messagerie', desc: 'Échangez avec le loueur en temps réel.' },
          { name: 'Mes réservations', desc: 'Suivi du statut : en attente, en cours, terminée.' },
        ],
      },
      {
        icon: 'arrow',
