const transversal = [
  { icon: 'chat', name: 'Messagerie & chat', desc: 'Conversations en temps réel locataire ↔ loueur.' },
  { icon: 'shield', name: 'Litiges & médiation', desc: 'Ouvrez un litige, suivez sa résolution.' },
  { icon: 'bell', name: 'Notifications', desc: 'Alertes sur chaque étape clé de vos locations.' },
  { icon: 'user', name: 'Compte & infos perso', desc: 'Identité, coordonnées, sécurité, suppression du compte.' },
];
---

<section id="parcours" class="scroll-mt-20">
  <div class="container-gl py-20 lg:py-24">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <span class="eyebrow">Toutes les étapes de l’app</span>
      <h2 class="mt-4 text-3xl font-semibold sm:text-4xl">Le parcours complet, écran par écran</h2>
      <p class="mt-4 text-muted">
        Du compte à la caution libérée — voici tout ce que fait GoodLease, côté locataire comme côté loueur.
      </p>
    </div>

    <div class="mt-14 grid gap-8 lg:grid-cols-2 lg:gap-10">
      {
        tracks.map((track) => (
          <div data-reveal>
            <div class="mb-6 flex items-baseline justify-between gap-3 border-b border-line pb-4">
              <h3 class="text-xl font-semibold">{track.label}</h3>
              <span class="text-sm text-muted">{track.tagline}</span>
            </div>

            <div class="space-y-5">
              {track.phases.map((phase, pi) => (
                <div
                  class="rounded-card border border-line bg-surface p-6 shadow-soft"
                  data-reveal
                  style={`--reveal-delay:${pi * 60}ms`}
                >
                  <div class="flex items-center gap-3">
                    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary-100 text-primary">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[phase.icon]} />
                    </span>
                    <h4 class="text-[15px] font-semibold">{phase.title}</h4>
                  </div>
                  <ul class="mt-4 space-y-3 border-l border-line pl-5">
                    {phase.steps.map((s) => (
                      <li class="relative">
                        <span class="absolute -left-[23px] top-[5px] h-2.5 w-2.5 rounded-full bg-primary ring-4 ring-primary-100" />
                        <p class="text-sm font-medium text-ink">{s.name}</p>
                        <p class="mt-0.5 text-sm leading-relaxed text-muted">{s.desc}</p>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <!-- Écrans transversaux -->
    <div class="mt-12" data-reveal>
      <h3 class="text-center text-sm font-semibold uppercase tracking-wider text-muted">
        Et tout au long du parcours
      </h3>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          transversal.map((t) => (
            <div class="flex items-start gap-3 rounded-card border border-line bg-surface p-5">
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-primary-100 text-primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[t.icon]} />
              </span>
              <div>
                <p class="text-sm font-semibold">{t.name}</p>
                <p class="mt-0.5 text-sm leading-relaxed text-muted">{t.desc}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
