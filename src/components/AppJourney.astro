        steps: [
          { name: 'Confirmer le retour', desc: 'Rendez le matériel à la date convenue.' },
          { name: 'État des lieux de sortie', desc: 'Photos de sortie, comparées à l’entrée.' },
          { name: 'Caution libérée', desc: 'L’empreinte de garantie est levée si tout est conforme.' },
        ],
      },
    ],
  },
  {
    label: 'Côté loueur',
    tagline: 'Rentabiliser votre matériel',
    color: 'ink',
    phases: [
      {
        icon: 'plus',
        title: 'Publier une annonce — 6 étapes',
        steps: [
          { name: '1 · Titre & catégorie', desc: 'Son, Lumières, Structures, Vidéo, Réception, Textile, Transport…' },
          { name: '2 · Détails & état', desc: 'Description et état (Neuf, Bon, Correct, Mauvais, Endommagé).' },
          { name: '3 · Photos', desc: 'Ajoutez depuis la galerie/l’appareil, puis réorganisez.' },
          { name: '4 · Prix, caution & quantité', desc: 'Prix par jour, dépôt de garantie, stock disponible.' },
          { name: '5 · Livraison', desc: 'Point de retrait ou livraison/installation chez le locataire.' },
          { name: '6 · Aperçu & publication', desc: 'Vérifiez l’ensemble puis publiez.' },
        ],
      },
      {
        icon: 'list',
        title: 'Gérer ses locations',
        steps: [
          { name: 'Mes annonces', desc: 'Modifiez, activez/désactivez ou supprimez vos annonces.' },
          { name: 'Mes locations', desc: 'Demandes entrantes, locations en cours et terminées.' },
          { name: 'Confirmer l’envoi', desc: 'Remettez le matériel avec un code de validation.' },
          { name: 'Confirmer la récupération', desc: 'Validez le retour : la caution du locataire est libérée.' },
        ],
      },
      {
        icon: 'wallet',
        title: 'Encaisser',
        steps: [
          { name: 'Récompenses & portefeuille', desc: 'Suivez vos gains et vos récompenses.' },
          { name: 'Détail des transactions', desc: 'Montant reçu et commission GoodLease, en transparence.' },
          { name: 'Virer les fonds', desc: 'Cashout vers votre compte bancaire (via Stripe).' },
