---
// Section 3D immersive (WebGL via Three.js). Three n'est chargé qu'au scroll (dynamic import
// déclenché par IntersectionObserver) pour ne pas peser sur le LCP. Le rendu est mis en pause
// hors-écran, désactivé en prefers-reduced-motion (image figée) et en mode Save-Data.
---

<section id="atelier" class="three-section relative overflow-hidden bg-ink text-white">
  <canvas data-three class="absolute inset-0 h-full w-full" aria-hidden="true"></canvas>
  <!-- Halo de marque + dégradé pour lisibilité du texte -->
  <div class="three-glow pointer-events-none absolute inset-0"></div>

  <div class="container-gl relative z-10 py-28 text-center lg:py-36">
    <div class="mx-auto max-w-2xl" data-reveal>
      <span class="eyebrow !bg-white/10 !text-white">Logistique simplifiée</span>
      <h2 class="mt-5 text-3xl font-semibold leading-tight sm:text-4xl lg:text-5xl">
        Montez votre événement<br />comme un pro.
      </h2>
      <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-white/70">
        Sonorisation, lumières, structures, mobilier… Réservez tout le matériel, recevez-le,
        installez, profitez. GoodLease orchestre chaque étape — vous gardez l’esprit à la fête.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="#parcours" class="btn bg-white text-ink hover:bg-white/90">Voir toutes les étapes</a>
        <a href="#telecharger" class="btn border border-white/25 text-white hover:bg-white/10">
          Télécharger l’app
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const canvas = document.querySelector<HTMLCanvasElement>('[data-three]');
  if (canvas) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    // @ts-ignore - connection est non standard
    const saveData = navigator.connection && navigator.connection.saveData;
    let started = false;

    const start = async () => {
      if (started || saveData) return;
      started = true;
      const THREE = await import('three');

      const section = canvas.closest('section') as HTMLElement;
      const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
      camera.position.set(0, 0, 9);

      // Lumières
      scene.add(new THREE.AmbientLight(0xffffff, 0.55));
      const key = new THREE.DirectionalLight(0xffffff, 1.6);
      key.position.set(5, 6, 8);
      scene.add(key);
      const blue = new THREE.PointLight(0x1675f3, 60, 40);
      blue.position.set(-6, -2, 4);
      scene.add(blue);

      const group = new THREE.Group();
      scene.add(group);

      const matBlue = new THREE.MeshStandardMaterial({ color: 0x1675f3, metalness: 0.35, roughness: 0.3 });
      const matLight = new THREE.MeshStandardMaterial({ color: 0xe9f2fe, metalness: 0.2, roughness: 0.45 });
      const matWire = new THREE.MeshStandardMaterial({ color: 0x4491f5, wireframe: true });

      type Obj = { mesh: any; floatAmp: number; floatSpeed: number; spin: number; phase: number };
      const objs: Obj[] = [];
      const add = (geo: any, mat: any, pos: [number, number, number], scale = 1) => {
        const mesh = new THREE.Mesh(geo, mat);
        mesh.position.set(...pos);
        mesh.scale.setScalar(scale);
        mesh.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, 0);
        group.add(mesh);
        objs.push({
          mesh,
          floatAmp: 0.2 + Math.random() * 0.35,
          floatSpeed: 0.5 + Math.random() * 0.6,
          spin: 0.08 + Math.random() * 0.18,
          phase: Math.random() * Math.PI * 2,
        });
        return mesh;
      };

      // « Matériel d'événement » stylisé en primitives low-poly
      add(new THREE.IcosahedronGeometry(1.25, 0), matBlue, [-3.2, 0.6, 0]); // sphère facettée
      add(new THREE.ConeGeometry(0.95, 1.7, 4), matLight, [3.1, 1.1, -1], 1); // projecteur / tente
      add(new THREE.BoxGeometry(1.3, 1.3, 1.3), matBlue, [2.6, -1.4, 0.5], 1); // enceinte / caisson
      add(new THREE.TorusGeometry(0.85, 0.28, 16, 40), matLight, [-2.7, -1.6, 0.5], 1); // anneau lumière
      add(new THREE.TetrahedronGeometry(1.0, 0), matWire, [0.2, 1.9, -1.5], 1); // structure filaire
      add(new THREE.DodecahedronGeometry(0.7, 0), matLight, [0.4, -2.0, 0.8], 1);
      add(new THREE.IcosahedronGeometry(1.7, 0), matWire, [0, 0, -3], 1); // halo filaire central
      add(new THREE.OctahedronGeometry(0.55, 0), matBlue, [-4.4, 1.9, -1], 1);

      // Parallax souris + progression scroll
      let pointerX = 0;
      let pointerY = 0;
      window.addEventListener('pointermove', (e) => {
        pointerX = (e.clientX / window.innerWidth) * 2 - 1;
        pointerY = (e.clientY / window.innerHeight) * 2 - 1;
      });
      let scrollProgress = 0;
      const updateScroll = () => {
        const r = section.getBoundingClientRect();
        const vh = window.innerHeight;
        scrollProgress = Math.max(0, Math.min(1, (vh - r.top) / (vh + r.height)));
      };
      updateScroll();
      window.addEventListener('scroll', updateScroll, { passive: true });

      const resize = () => {
        const w = canvas.clientWidth || section.clientWidth;
        const h = canvas.clientHeight || section.clientHeight;
        renderer.setSize(w, h, false);
        camera.aspect = w / h;
        camera.updateProjectionMatrix();
      };
      resize();
      if ('ResizeObserver' in window) new ResizeObserver(resize).observe(section);
      else window.addEventListener('resize', resize);

      const clock = new THREE.Clock();
      let running = true;
      let raf = 0;

      const render = () => {
        const t = clock.getElapsedTime();
        for (const o of objs) {
          o.mesh.position.y += Math.sin(t * o.floatSpeed + o.phase) * o.floatAmp * 0.01;
          o.mesh.rotation.x += o.spin * 0.01;
          o.mesh.rotation.y += o.spin * 0.013;
        }
        // Le groupe suit doucement la souris + tourne avec le scroll
        group.rotation.y += ((pointerX * 0.5 + scrollProgress * Math.PI * 0.6) - group.rotation.y) * 0.05;
        group.rotation.x += ((pointerY * 0.3) - group.rotation.x) * 0.05;
        renderer.render(scene, camera);
      };

      const loop = () => {
        if (!running) return;
        render();
        raf = requestAnimationFrame(loop);
      };

      if (reduce) {
        // Pas d'animation : un seul rendu figé
        render();
      } else {
        // Pause quand la section quitte l'écran
        if ('IntersectionObserver' in window) {
          const vis = new IntersectionObserver(
            (entries) => {
              const onScreen = entries[0].isIntersecting;
              if (onScreen && !running) {
                running = true;
                clock.start();
                loop();
              } else if (!onScreen && running) {
                running = false;
                cancelAnimationFrame(raf);
              }
            },
            { threshold: 0 },
          );
          vis.observe(section);
        }
        loop();
      }
    };

    if ('IntersectionObserver' in window && !saveData) {
      const io = new IntersectionObserver(
        (entries) => {
          if (entries.some((e) => e.isIntersecting)) {
            start();
            io.disconnect();
          }
        },
        { rootMargin: '300px' },
      );
      io.observe(canvas);
    } else if (!saveData) {
      start();
    }
  }
</script>

<style>
  .three-section {
    min-height: 80vh;
    display: flex;
    align-items: center;
  }
  .three-glow {
    background:
      radial-gradient(60% 50% at 50% 38%, rgba(22, 117, 243, 0.35), transparent 70%),
      radial-gradient(40% 40% at 80% 90%, rgba(68, 145, 245, 0.25), transparent 70%),
      linear-gradient(180deg, rgba(10, 12, 14, 0.2) 0%, rgba(10, 12, 14, 0.65) 100%);
  }
  [data-three] {
    display: block;
  }
</style>
