---
interface Props {
  src?: string;
  alt: string;
  /** Image prioritaire (hero) → chargement eager */
  eager?: boolean;
  class?: string;
}
const { src, alt, eager = false, class: className = '' } = Astro.props;
// Variante WebP servie en priorité (les captures ont un .webp à côté du .png), fallback PNG.
const webpSrc = src?.replace(/\.png$/, '.webp');
---

<div class={`phone ${className}`}>
  <div class="phone-frame">
    <div class="phone-notch" aria-hidden="true"></div>
    {
      src ? (
        <picture>
          <source srcset={webpSrc} type="image/webp" />
          <img
            src={src}
            alt={alt}
            class="phone-screen object-cover"
            loading={eager ? 'eager' : 'lazy'}
            decoding="async"
          />
        </picture>
      ) : (
        <div class="phone-screen flex flex-col items-center justify-center gap-2 bg-gradient-to-b from-primary-50 to-primary-100 text-center">
          <img src="/mark.svg" alt="" aria-hidden="true" class="h-12 w-12 opacity-80" />
          <span class="px-6 text-xs font-medium text-primary/70">{alt}</span>
        </div>
      )
    }
  </div>
</div>

<style>
  .phone {
    width: 100%;
    max-width: 280px;
  }
  .phone-frame {
    position: relative;
    aspect-ratio: 9 / 19.5;
    border-radius: 44px;
    background: #1a1c1e;
    padding: 10px;
    box-shadow:
      0 30px 60px -20px rgba(26, 28, 30, 0.35),
      inset 0 0 0 2px rgba(255, 255, 255, 0.06);
  }
  .phone-notch {
    position: absolute;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    width: 38%;
    height: 22px;
    border-radius: 0 0 14px 14px;
    background: #1a1c1e;
  }
  .phone-screen {
    width: 100%;
    height: 100%;
    border-radius: 34px;
    overflow: hidden;
  }
</style>
