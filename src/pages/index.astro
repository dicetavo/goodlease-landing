---
import Base from '../layouts/Base.astro';
import PhoneMockup from '../components/PhoneMockup.astro';
import PhoneScroller from '../components/PhoneScroller.astro';
import ThreeScene from '../components/ThreeScene.astro';
import AppJourney from '../components/AppJourney.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
import StoreBadges from '../components/StoreBadges.astro';
import { routes } from '../config';

import shotExplorer from '../assets/screenshots/01-explorer.png';
import shotFiche from '../assets/screenshots/02-fiche-produit.png';
import shotMicros from '../assets/screenshots/03-micros.png';
import shotCalendrier from '../assets/screenshots/04-calendrier.png';

const steps = [
  {
    n: '1',
    title: 'Recherchez',
    text: 'Trouvez tout le matériel de votre événement près du lieu : sonorisation, mobilier, tentes, déco, éclairage… Filtrez par dates et par lieu.',
  },
  {
    n: '2',
    title: 'Réservez',
    text: 'Réservez en quelques minutes. Le paiement et le dépôt de garantie sont sécurisés via Stripe — vous êtes protégé.',
  },
  {
    n: '3',
    title: 'Restituez',
    text: 'Récupérez le matériel, profitez de votre événement, puis restituez-le à la date convenue. Le dépôt de garantie est libéré automatiquement.',
  },
];

// Angle événementiel : ce que GoodLease équipe et comment il simplifie la logistique.
const eventTypes = [
  'Mariage',
  'Anniversaire',
  'Soirée & fête',
  'Séminaire & pro',
  'Festival & concert',
  'Réception',
  'Inauguration',
  'Vide-grenier',
];

const eventPerks = [
  {
    title: 'Tout au même endroit',
    text: 'Sonorisation, mobilier, tentes, déco, éclairage, vaisselle… Réunissez tout le matériel de l’événement sans multiplier les prestataires.',
    icon: '<path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>',
  },
  {
    title: 'Près du lieu',
    text: 'Louez à proximité du lieu de réception : moins de transport, retrait et installation simplifiés.',
    icon: '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>',
  },
  {
    title: 'Pile sur vos dates',
    text: 'Réservez au calendrier pour la durée exacte de l’événement, week-end et jours fériés compris.',
    icon: '<rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18M8 2v4M16 2v4"/>',
  },
  {
    title: 'Sans acheter ni stocker',
    text: 'Pas d’achat coûteux, pas de stockage après l’événement. Vous louez juste le temps qu’il faut.',
    icon: '<rect width="20" height="14" x="2" y="5" rx="2"/><path d="M2 10h20"/>',
  },
];

const owners = [
  { title: 'Rentabilisez votre matériel', text: 'Mettez en location ce que vous n’utilisez pas tous les jours et générez un revenu complémentaire.' },
  { title: 'Dépôt de garantie maîtrisé', text: 'Une empreinte de garantie est posée à chaque location et restituée si tout se passe bien.' },
  { title: 'Annonces modérées', text: 'Les annonces et les photos sont vérifiées pour garder une marketplace fiable et de qualité.' },
  { title: 'Paiement sécurisé via Stripe', text: 'Les fonds transitent par Stripe Connect. Vous recevez vos paiements directement sur votre compte.' },
];

const renters = [
  { title: 'Une grande variété de matériel', text: 'Du matériel événementiel et professionnel disponible près de chez vous, sans l’acheter.' },
  { title: 'Un prix juste', text: 'Louez au prix fixé par le loueur, en toute transparence. Tous les frais sont affichés avant de payer.' },
  { title: 'Un bail sécurisé', text: 'Identité des loueurs pros vérifiée, dépôt de garantie encadré, paiement intermédié.' },
  { title: 'Un support à l’écoute', text: 'Une question, un imprévu ? Notre service client vous accompagne du lundi au vendredi.' },
];

const trust = [
  { title: 'Vérification d’identité', text: 'Les loueurs professionnels font l’objet d’une vérification KYC (Stripe) conforme au DSA.' },
  { title: 'Dépôt de garantie', text: 'Empreinte bancaire posée puis restituée via Stripe — GoodLease n’est pas dépositaire des fonds.' },
  { title: 'Médiation de la consommation', text: 'En cas de litige, une médiation de la consommation est prévue, en plus de notre support.' },
  { title: 'Transparence des frais', text: 'Le montant de la commission et le prix TTC sont affichés au moment de la réservation.' },
];

// Étapes du scrollytelling (téléphone collant) — vraies captures de l'app.
const apercuSteps = [
  {
    image: shotExplorer,
    alt: 'Écran Explorer de l’app GoodLease',
    eyebrow: 'Étape 1 · Explorer',
    title: 'Trouvez le matériel près de chez vous',
    text: 'Parcourez par catégorie — son, lumières, structures, réception — et filtrez par lieu et par dates.',
  },
  {
    image: shotFiche,
    alt: 'Fiche produit dans l’app GoodLease',
    eyebrow: 'Étape 2 · Choisir',
    title: 'Tout est sur la fiche produit',
    text: 'Photos, prix par jour, dépôt de garantie, avis et profil du loueur : vous décidez en confiance.',
  },
  {
    image: shotCalendrier,
    alt: 'Calendrier de réservation dans l’app GoodLease',
    eyebrow: 'Étape 3 · Réserver',
    title: 'Choisissez vos dates au calendrier',
    text: 'Sélectionnez la période exacte de votre événement ; le total et la caution s’affichent avant de payer.',
  },
  {
    image: shotMicros,
    alt: 'Matériel audio professionnel à louer sur GoodLease',
    eyebrow: 'Étape 4 · Profiter',
    title: 'Du matériel pro, prêt pour le jour J',
    text: 'Paiement sécurisé via Stripe, remise par code, état des lieux : tout est cadré jusqu’à la restitution.',
  },
];

---

<Base title="GoodLease" homeSchema>
  <!-- Bandeau de confirmation double opt-in : Brevo redirige ici (/?confirm=1) après clic dans l'e-mail. -->
  <div id="confirm-banner" class="hidden border-b border-success/30 bg-success/10">
    <div class="container-gl flex items-center justify-center gap-2 py-3 text-center text-sm font-medium text-success">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 6 9 17l-5-5" />
      </svg>
      Votre inscription est confirmée — merci ! On vous prévient dès le lancement.
    </div>
  </div>

  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute -top-32 left-1/2 h-[480px] w-[820px] -translate-x-1/2 rounded-full bg-primary-100 blur-3xl opacity-60"></div>
    </div>
    <div class="container-gl grid items-center gap-12 py-16 lg:grid-cols-2 lg:py-24">
      <div>
        <span class="eyebrow">Bientôt disponible · iOS & Android</span>
        <h1 class="mt-5 text-4xl font-bold leading-[1.1] sm:text-5xl">
          Équipez vos événements sans rien acheter.
          <span class="text-primary">Rentabilisez le matériel que vous possédez.</span>
        </h1>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-muted">
          Sonorisation, mobilier, tentes, déco, éclairage… GoodLease réunit tout le matériel
          pour réussir vos événements, à louer près de chez vous et sur vos dates.
          Réservez en quelques clics, payez en sécurité, profitez d’un bail protégé.
        </p>

        <div id="telecharger" class="mt-8 max-w-lg scroll-mt-24 space-y-7">
          <div>
            <p class="mb-3 flex items-center gap-2 text-sm font-medium text-ink">
              <img src="/icon-1024.png" alt="" aria-hidden="true" class="h-8 w-8 rounded-[8px] shadow-soft" />
              Téléchargez l’app GoodLease
            </p>
            <StoreBadges />
          </div>

          <div class="border-t border-line pt-6">
            <p class="mb-3 text-sm font-medium text-muted">
              Pas encore lancée — rejoignez la liste d’attente, on vous prévient au lancement :
            </p>
            <WaitlistForm compact />
          </div>
        </div>
      </div>

      <div class="relative flex justify-center lg:justify-end">
        <PhoneMockup
          image={shotFiche}
          alt="Fiche produit dans l’application GoodLease"
          eager
          class="rotate-[2deg]"
        />
      </div>
    </div>
  </section>

  <!-- POUR VOS ÉVÉNEMENTS -->
  <section id="evenements" class="scroll-mt-20">
    <div class="container-gl py-20">
      <div class="mx-auto max-w-2xl text-center" data-reveal>
        <span class="eyebrow">Pour vos événements</span>
        <h2 class="mt-4 text-3xl font-semibold sm:text-4xl">Tout votre événement, équipé au même endroit</h2>
        <p class="mt-4 text-muted">
          Mariage, anniversaire, soirée, séminaire ou festival : réunissez tout le matériel
          dont vous avez besoin sur une seule plateforme, près du lieu et sur vos dates.
          GoodLease simplifie la logistique, vous profitez de l’événement.
        </p>
      </div>

      <div class="mt-10 flex flex-wrap justify-center gap-3">
        {
          eventTypes.map((e) => (
            <span class="rounded-full border border-line bg-surface px-4 py-2 text-sm font-medium text-ink">
              {e}
            </span>
          ))
        }
      </div>

      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          eventPerks.map((f) => (
            <div class="card">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary-100 text-primary">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <Fragment set:html={f.icon} />
                </svg>
              </div>
              <h3 class="mt-4 text-base font-semibold">{f.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">{f.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- COMMENT ÇA MARCHE -->
  <section id="comment-ca-marche" class="scroll-mt-20 border-y border-line bg-surface">
    <div class="container-gl py-20">
      <div class="mx-auto max-w-2xl text-center" data-reveal>
        <span class="eyebrow">Comment ça marche</span>
        <h2 class="mt-4 text-3xl font-semibold sm:text-4xl">Louer du matériel, simplement</h2>
        <p class="mt-4 text-muted">Trois étapes, de la recherche à la restitution.</p>
      </div>
      <div class="mt-14 grid gap-6 md:grid-cols-3">
        {
          steps.map((s) => (
            <div class="card">
              <div class="flex h-11 w-11 items-center justify-center rounded-full bg-primary text-lg font-bold text-white">
                {s.n}
              </div>
              <h3 class="mt-5 text-lg font-semibold">{s.title}</h3>
              <p class="mt-2 text-[15px] leading-relaxed text-muted">{s.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- L'APP EN IMAGES (scrollytelling) -->
  <PhoneScroller steps={apercuSteps} />

  <!-- SECTION 3D IMMERSIVE -->
  <ThreeScene />

  <!-- TOUTES LES ÉTAPES DE L'APP -->
  <AppJourney />

  <!-- POUR LES LOUEURS -->
  <section id="loueurs" class="scroll-mt-20">
    <div class="container-gl py-20">
      <div class="grid items-center gap-14 lg:grid-cols-2">
        <div class="order-2 flex justify-center lg:order-1">
          <PhoneMockup
            image={shotMicros}
            alt="Mettre du matériel en location sur GoodLease"
            class="-rotate-[2deg]"
          />
        </div>
        <div class="order-1 lg:order-2" data-reveal>
          <span class="eyebrow">Pour les loueurs</span>
          <h2 class="mt-4 text-3xl font-semibold sm:text-4xl">Votre matériel travaille pour vous</h2>
          <p class="mt-4 text-muted">
            Particulier ou professionnel, mettez vos équipements en location et gardez le contrôle.
          </p>
          <div class="mt-8 grid gap-5 sm:grid-cols-2">
            {
              owners.map((f) => (
                <div>
                  <h3 class="flex items-center gap-2 text-[15px] font-semibold">
                    <span class="text-primary">●</span>
                    {f.title}
                  </h3>
                  <p class="mt-1.5 text-sm leading-relaxed text-muted">{f.text}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- POUR LES LOCATAIRES -->
  <section class="border-y border-line bg-surface">
    <div class="container-gl py-20">
      <div class="mx-auto max-w-2xl text-center" data-reveal>
        <span class="eyebrow">Pour les locataires</span>
        <h2 class="mt-4 text-3xl font-semibold sm:text-4xl">Tout le matériel, sans l’acheter</h2>
      </div>
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          renters.map((f) => (
            <div class="card">
              <h3 class="text-base font-semibold">{f.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">{f.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- SÉCURITÉ & CONFIANCE -->
  <section>
    <div class="container-gl py-20">
      <div class="mx-auto max-w-2xl text-center" data-reveal>
        <span class="eyebrow">Sécurité &amp; confiance</span>
        <h2 class="mt-4 text-3xl font-semibold sm:text-4xl">Louez l’esprit tranquille</h2>
        <p class="mt-4 text-muted">
          La sécurité du bail est au cœur de GoodLease.
          <a href={routes.safety} class="font-medium text-primary hover:underline">En savoir plus</a>.
        </p>
      </div>
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          trust.map((f) => (
            <div class="rounded-card border border-line bg-surface p-6">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary-100">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1675F3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                  <path d="M9 12l2 2 4-4" />
                </svg>
              </div>
              <h3 class="mt-4 text-base font-semibold">{f.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">{f.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA WAITLIST -->
  <section>
    <div class="container-gl py-20">
      <div class="mx-auto max-w-3xl rounded-card bg-primary px-8 py-12 text-center shadow-card sm:px-12">
        <img
          src="/icon-1024.png"
          alt="Icône de l’application GoodLease"
          class="mx-auto h-20 w-20 rounded-[20px] shadow-lg"
          width="80"
          height="80"
        />
        <h2 class="mt-6 text-3xl font-semibold text-white sm:text-4xl">Soyez les premiers informés du lancement</h2>
        <p class="mx-auto mt-3 max-w-xl text-primary-100">
          Bientôt disponible sur l’App Store et Google Play. Laissez votre e-mail : on vous prévient dès la sortie.
        </p>

        <div class="mt-8 rounded-card bg-white/10 px-6 py-6">
          <StoreBadges center />
        </div>

        <div class="mx-auto mt-6 max-w-lg rounded-card bg-surface p-5 text-left">
          <WaitlistForm compact />
        </div>
      </div>
    </div>
  </section>

  <script>
    // Retour depuis l'e-mail de confirmation Brevo : on révèle le bandeau puis on nettoie l'URL
    // (replaceState) pour qu'un rafraîchissement ne le ré-affiche pas.
    if (new URLSearchParams(location.search).get('confirm') === '1') {
      document.getElementById('confirm-banner')?.classList.remove('hidden');
      history.replaceState(null, '', location.pathname);
    }
  </script>
</Base>
