---
import Base from '../layouts/Base.astro';
import ContactForm from '../components/ContactForm.astro';
import { emails, company } from '../config';
---

<Base
  title="Contacter le service client"
  description="Contactez le service client GoodLease : formulaire, e-mail et horaires. Une question, un problème technique ou un signalement ? Nous vous répondons."
>
  <section class="border-b border-line bg-surface">
    <div class="container-gl py-12 sm:py-16">
      <a href="/" class="text-sm font-medium text-primary hover:underline">← Retour à l’accueil</a>
      <h1 class="mt-4 text-3xl font-semibold sm:text-4xl">Contacter le service client</h1>
      <p class="mt-4 max-w-2xl text-[15px] leading-relaxed text-muted">
        Une question, un imprévu, un signalement&nbsp;? Écrivez-nous via le formulaire ci-dessous, nous
        revenons vers vous au plus vite.
      </p>
    </div>
  </section>

  <section class="container-gl py-12">
    <div class="grid gap-10 lg:grid-cols-[1.6fr_1fr]">
      <div class="card">
        <ContactForm />
      </div>

      <aside class="space-y-6">
        <div class="card">
          <h2 class="text-base font-semibold">Nous écrire directement</h2>
          <ul class="mt-3 space-y-2 text-sm">
            <li>Service client : <a href={`mailto:${emails.support}`} class="font-medium text-primary hover:underline">{emails.support}</a></li>
            <li>Contact général : <a href={`mailto:${emails.contact}`} class="font-medium text-primary hover:underline">{emails.contact}</a></li>
            <li>RGPD : <a href={`mailto:${emails.rgpd}`} class="font-medium text-primary hover:underline">{emails.rgpd}</a></li>
            <li>Signalement : <a href={`mailto:${emails.signalement}`} class="font-medium text-primary hover:underline">{emails.signalement}</a></li>
          </ul>
        </div>

        <div class="card">
          <h2 class="text-base font-semibold">Horaires du support</h2>
          <p class="mt-3 text-sm text-muted">
            Du lundi au vendredi<br />
            9h – 12h et 14h – 18h
          </p>
          <p class="mt-3 text-sm text-muted">Téléphone : {company.phone}</p>
        </div>
      </aside>
    </div>
  </section>
</Base>
